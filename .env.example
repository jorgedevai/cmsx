# ═══════════════════════════════════════════════════════════════════════
# CMSx — Environment Configuration
# Copy this file to .env and fill in the required values.
# Or run: ./setup.sh (generates .env automatically with secure defaults)
# ═══════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=cmsx
POSTGRES_PASSWORD=          # REQUIRED — choose a strong password
POSTGRES_DB=cmsx

# ── Security ──────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=
JWT_EXPIRATION=3600

# ── URLs & Ports ─────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080

# Frontend URL(s) allowed to make API requests (comma-separated)
# Set this to your actual domain in production
CORS_ORIGINS=http://localhost:3000

# Public URL where the backend is accessible (assets are served from /uploads path)
# For local storage: http://your-domain:8080
# For R2: https://pub-xxx.r2.dev
NEXT_PUBLIC_ASSET_URL=http://localhost:8080

# ── Storage ──────────────────────────────────────────────────────────
# Options: "local" (files stored in Docker volume) or "r2" (Cloudflare R2)
STORAGE_TYPE=local

# Cloudflare R2 (only if STORAGE_TYPE=r2)
# R2_BUCKET=your-bucket
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY=your-access-key
# R2_SECRET_KEY=your-secret-key
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── AI Content Generation (optional) ────────────────────────────────
AI_ENABLED=false
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Cross-Domain Cookies ────────────────────────────────────────────
# Set ONLY if frontend and backend are on different subdomains
# Example: frontend on app.example.com, backend on api.example.com
# COOKIE_DOMAIN=.example.com
# Set to "true" when using HTTPS (required for secure cookies)
# SECURE_COOKIES=true

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_AUTH=5
RATE_LIMIT_GLOBAL=100

# ── Logging ──────────────────────────────────────────────────────────
# Options: error, warn, info, debug, trace
RUST_LOG=info
